# Obtenelo en https://www.mercadopago.com.ar/developers/panel/app
# Usá el Access Token de PRODUCCIÓN (empieza con APP_USR-...) o TEST para sandbox.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URLs a las que MP redirige al usuario tras el pago
MP_SUCCESS_URL=http://localhost:4200/cart/success
MP_FAILURE_URL=http://localhost:4200/cart/failure
MP_PENDING_URL=http://localhost:4200/cart/pending

SERVER_ADDRESS=:8080
FRONTEND_URL=http://localhost:4200
JWT_SECRET=cambia-este-secret-en-produccion
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=user
DATABASE_PASS=password
DATABASE_NAME=core

# --- Configuración AFIP ---
# AFIP_ENABLED: "true" para activar la generación de facturas, "false" para desactivarla
AFIP_ENABLED=true
# AFIP_ENVIRONMENT: "testing" (homologación) o "production" (producción)
AFIP_ENVIRONMENT=testing
# AFIP_CUIT: CUIT de la empresa sin guiones
AFIP_CUIT=20123456789
# AFIP_CERT_PATH: Ruta al certificado (.crt) físico
AFIP_CERT_PATH=./certs/afip_cert.crt
# AFIP_CERT_TOKEN: Certificado en Base64 (alternativa a usar archivo físico)
# AFIP_CERT_TOKEN=
# AFIP_KEY_PATH: Ruta a la clave privada (.key) física
AFIP_KEY_PATH=./certs/afip_key.key
# AFIP_KEY_TOKEN: Clave privada en Base64 (alternativa a usar archivo físico)
# AFIP_KEY_TOKEN=
