# Obtenelo en https://www.mercadopago.com.ar/developers/panel/app
# Usá el Access Token de PRODUCCIÓN (empieza con APP_USR-...) o TEST para sandbox.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URLs a las que MP redirige al usuario tras el pago
MP_SUCCESS_URL=http://localhost:4200/cart/success
MP_FAILURE_URL=http://localhost:4200/cart/failure
MP_PENDING_URL=http://localhost:4200/cart/pending

SERVER_ADDRESS=:8080
FRONTEND_URL=http://localhost:4200
JWT_SECRET=cambia-este-secret-en-produccion
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=user
DATABASE_PASS=password
DATABASE_NAME=core
